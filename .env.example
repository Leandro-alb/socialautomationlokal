# OpenAI
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
OPENAI_MODEL=gpt-5.1

# Postiz (your current local setup runs on port 5001)
POSTIZ_BASE_URL=http://127.0.0.1:5001/api
POSTIZ_API_KEY=<YOUR_POSTIZ_API_KEY>

# Optional explicit integration IDs
POSTIZ_INSTAGRAM_INTEGRATION_ID=
POSTIZ_TIKTOK_INTEGRATION_ID=
POSTIZ_PUBLIC_UPLOAD_BASE_URL=

# Source + behavior
ARTICLE_SOURCE_URL=https://gastronews.org
MAX_IMAGES=10
DRY_RUN=false
